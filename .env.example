# =============================================================================
# Help Me Invest — environment variables (TEMPLATE)
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values for local dev.
# NEVER commit real secrets. `.env*` files are gitignored (except this example).
#
# Most entries below are placeholders for Phase 2 integrations and are NOT
# required to run the Phase 1 front end. They document the config surface
# described in the project brief; exact providers are confirmed per FEAT card.
# =============================================================================

# --- Site ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Supabase (accounts, auth, storage) — FEAT-1..5, images ---
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Payload CMS — FEAT-7 ---
PAYLOAD_SECRET=""
DATABASE_URI=""

# --- Video streaming (Bunny Stream — never serve video off Vercel/Supabase) — FEAT-6 ---
BUNNY_STREAM_LIBRARY_ID=""
BUNNY_STREAM_API_KEY=""

# --- CRM (GoHighLevel) — FEAT-11 ---
GHL_API_KEY=""
GHL_LOCATION_ID=""

# --- Transactional email — FEAT-18 ---
EMAIL_API_KEY=""
EMAIL_FROM_ADDRESS=""

# --- SMS (consent + STOP handling) — FEAT-19 ---
SMS_API_KEY=""
SMS_SENDER_ID=""

# --- Analytics (privacy-respecting, e.g. PostHog) — FEAT-16 ---
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
