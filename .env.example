# =============================================================================
# Help Me Invest — environment variables (TEMPLATE)
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values for local dev.
# NEVER commit real secrets. `.env*` files are gitignored (except this example).
#
# Values below are CLEARLY-MARKED PLACEHOLDERS, not real secrets. Most are for
# Phase 2 integrations and are NOT required to run the Phase 1 front end — the
# front end runs with only NEXT_PUBLIC_SITE_URL (and even that falls back to
# localhost). The finalised Phase 2 stack: Railway (hosting + DB + storage),
# Clerk (auth), Sanity (CMS), Cloudflare Stream (video). See PROJECT_CONTEXT.md §2.
# =============================================================================

# --- Site ---
# Local dev uses localhost; on Railway this is set to the live URL
# (https://help-me-invest-production.up.railway.app) so canonical/OG links resolve.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Railway: database + storage (Phase 2) ---
# Provided by Railway when you add the Postgres plugin (injected as DATABASE_URL).
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# --- Clerk: auth — Google SSO + email verification (Phase 2) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_your_publishable_key"
CLERK_SECRET_KEY="sk_test_your_secret_key"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# --- Sanity: CMS (also drives marketing landing pages via templates) (Phase 2) ---
# PROJECT_ID + DATASET are public (shipped in the client bundle + embedded Studio).
# READ_TOKEN (private-dataset reads + drafts) and REVALIDATE_SECRET (publish
# webhook → on-demand revalidation) are real secrets — Railway-only.
NEXT_PUBLIC_SANITY_PROJECT_ID="your_sanity_project_id"
NEXT_PUBLIC_SANITY_DATASET="production"
SANITY_API_READ_TOKEN="your_sanity_read_token"
SANITY_REVALIDATE_SECRET="your_sanity_webhook_secret"

# --- Cloudflare Stream: video with DRM (Widevine/FairPlay) for gated content (Phase 2) ---
CLOUDFLARE_ACCOUNT_ID="your_cloudflare_account_id"
CLOUDFLARE_STREAM_API_TOKEN="your_cloudflare_stream_api_token"
NEXT_PUBLIC_CLOUDFLARE_STREAM_CUSTOMER_CODE="your_stream_customer_code"

# --- CRM (GoHighLevel) — carried over from the brief (Phase 2) ---
GHL_API_KEY="your_ghl_api_key"
GHL_LOCATION_ID="your_ghl_location_id"

# --- Transactional email — carried over from the brief (Phase 2) ---
EMAIL_API_KEY="your_email_api_key"
EMAIL_FROM_ADDRESS="hello@helpmeinvest.com.au"

# --- SMS (consent + STOP handling) — carried over from the brief (Phase 2) ---
SMS_API_KEY="your_sms_api_key"
SMS_SENDER_ID="your_sms_sender_id"

# --- Analytics (privacy-respecting, e.g. PostHog) — carried over from the brief (Phase 2) ---
NEXT_PUBLIC_POSTHOG_KEY="your_posthog_key"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
